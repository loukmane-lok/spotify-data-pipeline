# ============================================================
# Spotify Data Pipeline — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ============================================================

# --- PostgreSQL (Airflow metadata DB) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# --- Airflow Admin ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_PASSWORD=changeme

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_PREFIX=bronze/

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC=spotify-events
KAFKA_GROUP_ID=spotify-s3-consumer
BATCH_SIZE=10

# --- Simulator ---
USER_COUNT=20
EVENT_INTERVAL_SECONDS=1

# --- Snowflake ---
SNOWFLAKE_USER=your-snowflake-user
SNOWFLAKE_PASSWORD=your-snowflake-password
SNOWFLAKE_ACCOUNT=your-account.region.cloud
SNOWFLAKE_WAREHOUSE=SPOTIFY_COMPUTE_WH
SNOWFLAKE_DATABASE=SPOTIFY_DB
SNOWFLAKE_SCHEMA=BRONZE
SNOWFLAKE_TABLE=RAW_EVENTS

# --- Airflow ---
AIRFLOW_UID=50000
